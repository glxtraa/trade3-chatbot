# Application Configuration
PORT=3000

# WhatsApp API Credentials
# Replace these with your actual Meta Developer Console credentials
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_VERIFY_TOKEN=your_secure_verify_token_for_webhook

# OpenAI API Credentials
# Used for parsing chat history into PO JSON
OPENAI_API_KEY=your_openai_api_key_here

# Internal Trade Finance API
# The endpoint where the validated PO JSON will be sent
TRADE_API_URL=https://api.ourtradeplatform.com/v1/purchase-orders
TRADE_API_KEY=your_internal_trade_api_key_here
TEST_MODE=true
